generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  division     String
  description  String
  color        String
  tools        String?
  systemPrompt String
  rawMarkdown  String
  isCustom     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
